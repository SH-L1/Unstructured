# OpenAI LLM
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1
AI_PROVIDER=openai

# PostgreSQL knowledge/document ingestion target
DB_HOST=localhost
DB_PORT=5432
DB_NAME=complaintdb
DB_USER=complaint_user
DB_PASSWORD=complaint_pass
WORKER_DB_USER=complaint_worker
WORKER_DB_PASSWORD=set_a_dedicated_least_privilege_password

# ---------------------------------------------------------------------------
# Public data sources used by the current AI/RAG data collection flow
# ---------------------------------------------------------------------------

# 공공데이터포털(data.go.kr) serviceKey.
# 아래 서비스는 공공데이터포털에서 활용 신청 후 발급받은 serviceKey를 사용한다.
# - 국민권익위원회_민원정책 질의응답조회서비스
# - 국민권익위원회_민원빅데이터_분석정보_API_2025
# - 국민권익위원회_민원빅데이터_분석정보_API_2024
# - 국민권익위원회_민원빅데이터_분석정보_API_2023
# - 국민권익위원회_민원빅데이터_분석정보_API_2022
#
# 현재 클라이언트는 아래 두 변수명을 읽는다.
# 두 서비스가 같은 공공데이터포털 serviceKey를 쓰면 두 변수에 같은 값을 넣는다.
POLICY_QNA_API_KEY=your_data_go_kr_service_key_here
POLICY_QNA_BASE_URL=https://apis.data.go.kr/1140100/CivilPolicyQnaService

COMPLAINT_BIGDATA_API_KEY=your_data_go_kr_service_key_here
COMPLAINT_BIGDATA_SERVICE_KEY=
COMPLAINT_BIGDATA_BASE_URL=https://apis.data.go.kr/1140100/minAnalsInfoView5

# 법제처 국가법령정보 공동활용 OPEN API.
# 국가법령/자치법규 검색 및 본문 조회에 사용한다.
LAW_API_OC=your_law_open_api_oc_here

# 민원사무서식 OPEN API.
# 별도 API 키 없이 요청 URL만 사용한다.
MINWON_FORM_API_BASE_URL=https://www.chungnam.go.kr/cnbbs/openApiMinwonForm.do
MINWON_FORM_API_NUM_OF_ROWS=100

# ---------------------------------------------------------------------------
# Ingestion switches
# ---------------------------------------------------------------------------

# 공공데이터포털 보조 자료 수집.
# 수집 자료는 법적 근거가 아니라 참고자료로 저장한다.
AUXILIARY_SOURCE_SYNC_ENABLED=false
COMPLAINT_BIGDATA_API_SYNC_ENABLED=false
POLICY_QNA_API_SYNC_ENABLED=false
AUXILIARY_SOURCE_DISPLAY=5
AUXILIARY_SOURCE_QUERIES=아산시 민원,아산시 생활불편,아산시 행정절차,아산시 쓰레기 폐기물,아산시 도로 교통 주차,아산시 소음 악취 환경,아산시 상하수도,아산시 건축 주택 공동주택,아산시 공원 녹지,아산시 보건 위생,아산시 안전 재난

# 법제처 국가법령정보 수집.
OFFICIAL_SOURCE_SYNC_ENABLED=false
OFFICIAL_SOURCE_SEARCH_DISPLAY=5
OFFICIAL_SOURCE_MAX_DOCUMENTS=200
# 국가법령정보 공동활용 OPEN API에서 국가법령으로 수집 가능한 법률명.
# URGENTMODIFY 기준상 이 목록은 수집 후 조문/시행일/출처 검증을 통과해야만
# VERIFIED_OFFICIAL 법적 근거로 사용할 수 있다.
OFFICIAL_LAW_QUERIES=민원 처리에 관한 법률,행정절차법,개인정보 보호법,공공기관의 정보공개에 관한 법률,지방자치법,지방행정제재ㆍ부과금의 징수 등에 관한 법률,질서위반행위규제법,행정대집행법,폐기물관리법,도로법,도로교통법,주차장법,소음진동관리법,악취방지법,대기환경보전법,물환경보전법,하수도법,수도법,하천법,소하천정비법,건축법,건축물관리법,주택법,공동주택관리법,국토의 계획 및 이용에 관한 법률,도시공원 및 녹지 등에 관한 법률,옥외광고물 등의 관리와 옥외광고산업 진흥에 관한 법률,식품위생법,공중위생관리법,감염병의 예방 및 관리에 관한 법률,재난 및 안전관리 기본법,시설물의 안전 및 유지관리에 관한 특별법,어린이놀이시설 안전관리법,동물보호법,가축분뇨의 관리 및 이용에 관한 법률,가축전염병 예방법,장애인복지법,장애인ㆍ노인ㆍ임산부 등의 편의증진 보장에 관한 법률,교통약자의 이동편의 증진법,화학물질관리법,위험물안전관리법

# 아산시 자치법규는 국가법령이 아니므로 현재 sync_official_sources.py의
# VERIFIED_OFFICIAL 국가법령 적재 대상에는 포함하지 않는다.
# 법제처 자치법규 API(target=ordin) 또는 아산시 자치법규 시스템에서 별도 수집 후,
# 지자체 관할/시행일/폐지 여부 검증 정책을 추가한 뒤 법적 근거로 승격한다.
# 우선 검색/후보 수집에 사용할 아산시 자치법규 검색어:
ASAN_ORDINANCE_SYNC_ENABLED=false
ASAN_ORDINANCE_INTERVAL_MINUTES=1440
ASAN_ORDINANCE_JURISDICTION_CODE=ASAN
ASAN_ORDINANCE_SEARCH_DISPLAY=10
ASAN_ORDINANCE_MAX_DOCUMENTS=300
ASAN_ORDINANCE_SEARCH_QUERIES=아산시 민원,아산시 행정기구,아산시 사무위임,아산시 폐기물,아산시 도로,아산시 주차장,아산시 교통안전,아산시 소음,아산시 악취,아산시 수도,아산시 하수도,아산시 건축,아산시 공동주택,아산시 도시공원,아산시 옥외광고물,아산시 식품위생,아산시 공중위생,아산시 감염병,아산시 재난,아산시 안전관리,아산시 어린이놀이시설,아산시 동물보호,아산시 가축분뇨,아산시 장애인,아산시 교통약자

# Shared public API runtime limits
PUBLIC_API_TIMEOUT_SECONDS=10
PROVIDER_MAX_ATTEMPTS=3
PROVIDER_RETRY_BASE_SECONDS=1
PROVIDER_CIRCUIT_FAILURE_THRESHOLD=3
PROVIDER_CIRCUIT_OPEN_SECONDS=60
PROVIDER_LAW_API_MAX_ATTEMPTS=3

# ---------------------------------------------------------------------------
# Asan GIS spatial data mart ingestion
# ---------------------------------------------------------------------------
# Set true only after you have downloaded official CSV/GeoJSON files or have
# approved official API URLs. These records are operational context, not legal
# evidence. LLMs must not generate coordinates; coordinates come from these
# sources only.
SPATIAL_SYNC_ENABLED=false
# Optional override. Leave empty if COMPLAINT_BIGDATA_API_KEY or POLICY_QNA_API_KEY
# already contains your data.go.kr serviceKey.
SPATIAL_DATA_GO_KR_SERVICE_KEY=

# SGIS OpenAPI credentials. Use these only when a SPATIAL_*_GEOJSON variable
# points directly to an SGIS API URL. If you downloaded SGIS data as a file,
# leave these empty and point SPATIAL_ADMIN_BOUNDARIES_GEOJSON to the file path.
SGIS_CONSUMER_KEY=
SGIS_CONSUMER_SECRET=
# Leave this empty for normal use. The ingestion code issues and refreshes
# short-lived SGIS access tokens from SGIS_CONSUMER_KEY/SGIS_CONSUMER_SECRET.
SGIS_ACCESS_TOKEN=
SGIS_AUTH_URL=https://sgisapi.kostat.go.kr/OpenAPI3/auth/authentication.json
# Direct SGIS administrative-boundary API URL, if using API download instead of
# a prepared GeoJSON file. Do not include accessToken; the code adds it.
SGIS_ADMIN_BOUNDARY_URL=

# Phase 1: base location, jurisdiction, parking, parks
SPATIAL_ADMIN_BOUNDARIES_GEOJSON=data/spatial/asan_admin_boundaries.geojson
# Optional API-download output path. Use this when SPATIAL_ADMIN_BOUNDARIES_GEOJSON
# is itself a URL and you still want to persist the downloaded GeoJSON locally.
SPATIAL_ADMIN_BOUNDARIES_OUTPUT_GEOJSON=data/spatial/asan_admin_boundaries.geojson
SPATIAL_ADDRESS_POINTS_CSV=data/spatial/asan_address_points.csv
SPATIAL_ROAD_SEGMENTS_GEOJSON=data/spatial/asan_road_segments.geojson
SPATIAL_PARKING_LOTS_CSV=data/spatial/asan_parking_lots.csv
SPATIAL_PARKING_RESTRICTIONS_CSV=data/spatial/asan_parking_restrictions.csv
SPATIAL_PARKS_CSV=data/spatial/asan_parks.csv

# Phase 2: safety and traffic context
SPATIAL_CCTV_CSV=data/spatial/asan_cctv.csv
SPATIAL_STREETLIGHTS_CSV=data/spatial/asan_streetlights.csv
SPATIAL_ROAD_SIGNS_CSV=data/spatial/asan_road_signs.csv
SPATIAL_VMS_CSV=data/spatial/asan_vms.csv

# Phase 3: domain-specific operational ledgers
SPATIAL_LIVESTOCK_FARMS_CSV=data/spatial/asan_livestock_farms.csv
SPATIAL_PUBLIC_HOUSING_CSV=data/spatial/asan_public_housing.csv
SPATIAL_WATER_FACILITIES_CSV=data/spatial/asan_water_facilities.csv
SPATIAL_SEWER_FACILITIES_CSV=data/spatial/asan_sewer_facilities.csv
SPATIAL_ROAD_MANAGEMENT_CSV=data/spatial/asan_road_management.csv

# ---------------------------------------------------------------------------
# Downloaded local datasets
# ---------------------------------------------------------------------------
# 202605_건물DB_전체분(주소정보). Use this as the canonical address point file
# after converting/normalizing to CSV columns that include road address, jibun
# address, building name/id, administrative/legal-dong codes, latitude, and
# longitude. It should point to the same file as SPATIAL_ADDRESS_POINTS_CSV.
BUILDING_DB_ADDRESS_CSV=data/spatial/asan_address_points.csv
BUILDING_DB_SOURCE_DIR=data/spatial/asan_address

# 2018~2026 Asan civil complaint manuals. Put original PDF/HWP/HWPX/XLSX files
# in this directory. A later normalizer will write PROCEDURE records to DB.
MINWON_MANUAL_DIR=data/minwon_manuals

# Current Asan ordinance list. This is reference metadata only; ordinance body
# text is collected again through the National Law API using LAW_API_OC.
ASAN_CURRENT_ORDINANCE_LIST_FILE=data/local_ordinances/asan_current_ordinances.xlsx

# Asan Saeol public consultation complaints. Use only de-identified 2021+
# records. Legal evidence use is always forbidden.
SAEOL_PUBLIC_COMPLAINTS_FILE=data/saeol/asan_saeol_public_complaints_2021_2026.xlsx

# Asan city organization chart/work assignment data.
ASAN_ORGANIZATION_FILE=data/organization/asan_city_organization.xlsx

# AIHub datasets. Keep these out of legal-evidence ingestion. They are training,
# evaluation, style, or document-understanding candidates only.
AIHUB_DOCUMENT_VISUAL_DIR=data/aihub/document_visual
AIHUB_PUBLIC_COMPLAINT_LLM_DIR=data/aihub/public_complaint_llm
AIHUB_ADMINISTRATIVE_LAW_LLM_DIR=data/aihub/administrative_law_llm
